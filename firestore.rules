rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    function uidUnchanged() {
      return !('ownerId' in request.resource.data) || request.resource.data.ownerId == request.auth.uid;
    }

    function uidNotModified() {
      return !('ownerId' in request.resource.data) || request.resource.data.ownerId == resource.data.ownerId;
    }

    // Domain Validators
    function isValidColumn(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.ownerId == request.auth.uid;
    }

    function isValidTask(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.ownerId == request.auth.uid;
    }

    function isValidGoal(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.ownerId == request.auth.uid &&
             data.level in ['year', 'quarter', 'month', 'week'] &&
             data.targetValue is number &&
             data.unit is string &&
             data.updateMethod in ['manual', 'task-linked'];
    }

    // Columns
    match /columns/{columnId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow create: if isAuthenticated() && isValidColumn(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isDocOwner() && isValidColumn(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && isDocOwner();
    }
    
    // Tasks
    match /tasks/{taskId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow create: if isAuthenticated() && isValidTask(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isDocOwner() && isValidTask(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && isDocOwner();
    }

    // Goals
    match /goals/{goalId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow create: if isAuthenticated() && isValidGoal(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isDocOwner() && isValidGoal(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && isDocOwner();
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
